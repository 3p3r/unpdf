{
  "name": "unpdf",
  "version": "0.6.4",
  "description": "Node.js and browser bindings for unpdf (WASI wasm)",
  "main": "unpdf.wasi.cjs",
  "types": "index.d.ts",
  "browser": "unpdf.wasi-browser.mjs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iyulab/unpdf.git",
    "directory": "bindings/node"
  },
  "keywords": ["pdf", "markdown", "napi-rs", "wasm"],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "node": "./unpdf.wasi.cjs",
      "browser": "./unpdf.wasi-browser.mjs",
      "default": "./unpdf.wasi.cjs"
    },
    "./parallel": {
      "types": "./index.d.ts",
      "node": "./unpdf-parallel.wasi.cjs",
      "browser": "./unpdf-parallel.wasi-browser.mjs",
      "default": "./unpdf-parallel.wasi.cjs"
    }
  },
  "files": [
    "index.d.ts",
    "unpdf.wasi.cjs",
    "unpdf.wasi-browser.mjs",
    "unpdf.wasm32-wasi.wasm",
    "unpdf-parallel.wasi.cjs",
    "unpdf-parallel.wasi-browser.mjs",
    "unpdf-parallel.wasm32-wasi.wasm",
    "wasi-worker.mjs",
    "wasi-worker-browser.mjs"
  ],
  "napi": {
    "binaryName": "unpdf",
    "targets": ["wasm32-wasip1-threads"]
  },
  "engines": {
    "node": ">= 18"
  },
  "dependencies": {
    "@napi-rs/wasm-runtime": "^1.1.4"
  },
  "scripts": {
    "build": "npm run build:parallel && npm run build:sequential",
    "build:parallel": "napi build -c napi.parallel.json --platform --release -t wasm32-wasip1-threads && rm -f browser.js index.js && mv -f unpdf-parallel.wasi-browser.js unpdf-parallel.wasi-browser.mjs",
    "build:sequential": "UNPDF_WASM_SEQUENTIAL=1 napi build --platform --release -t wasm32-wasip1-threads && rm -f browser.js index.js && mv -f unpdf.wasi-browser.js unpdf.wasi-browser.mjs",
    "test": "node --test test/smoke.mjs"
  },
  "devDependencies": {
    "@emnapi/core": "^1.5.0",
    "@emnapi/runtime": "^1.5.0",
    "@napi-rs/cli": "^3.2.0",
    "@tybys/wasm-util": "^0.10.0"
  }
}
